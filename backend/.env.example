# Copy this file to .env and fill in the values before deploying.

# Database — do not change this when using Docker (overridden by docker-compose)
DATABASE_URL=sqlite:///./budget.db

# Allowed origins — set to your server IP or domain
# Example with IP:     ALLOWED_ORIGINS=http://192.168.1.100
# Example with domain: ALLOWED_ORIGINS=https://budget.mysite.com
ALLOWED_ORIGINS=http://YOUR_SERVER_IP

# Secret key — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET

# Admin credentials — change before deploying
ADMIN_USERNAME=admin
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD
