# Copy this file to .env and fill in the values before deploying.

# Database — do not change this when using Docker (overridden by docker-compose)
DATABASE_URL=sqlite:///./budget.db

# Allowed origins — set to your server IP or domain
# Example with IP:     ALLOWED_ORIGINS=http://192.168.1.100
# Example with domain: ALLOWED_ORIGINS=https://budget.mysite.com
ALLOWED_ORIGINS=http://YOUR_SERVER_IP

# Secret key — generate with:
# python -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=REPLACE_WITH_GENERATED_SECRET

# Admin account — created automatically on first startup
ADMIN_USERNAME=admin
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=REPLACE_WITH_STRONG_PASSWORD

# Registration — set to false to prevent new users from registering
REGISTRATION_ENABLED=true

# Debug mode — set to false in production (true skips email verification)
DEBUG=false

# AI — Groq (used for chat assistant)
# Get your key at https://console.groq.com
GROQ_API_KEY=

# AI — Ollama (used for spending insights, runs locally via Docker)
OLLAMA_URL=http://ollama:11434
OLLAMA_MODEL=phi3:mini

# Email (used to send verification emails to new users)
# Yahoo: use an App Password (not your account password)
# Gmail: use an App Password generated in Google Account security settings
MAIL_USER=your_email@yahoo.com
MAIL_PASSWORD=your_app_password
MAIL_HOST=smtp.mail.yahoo.com
MAIL_PORT=587

# Public URL of your app — used to build the verification link in emails
APP_URL=https://your-domain.com
